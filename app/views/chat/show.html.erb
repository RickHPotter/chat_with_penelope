<div class="min-h-screen bg-[radial-gradient(circle_at_top,_rgba(56,189,248,0.12),_transparent_35%),linear-gradient(180deg,_#020617_0%,_#020617_100%)]">
  <%= turbo_stream_from [@chat, "messages"] %>

  <main class="mx-auto flex min-h-screen max-w-4xl flex-col px-4 py-4 sm:px-6 lg:px-8">
    <header class="mb-4 flex items-center justify-between border-b border-white/10 pb-4">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-sky-300/80">Local French Tutor</p>
        <h1 class="mt-2 text-2xl font-semibold tracking-tight text-white sm:text-3xl">French Tutor</h1>
      </div>
      <div class="rounded-full border border-sky-400/20 bg-sky-400/10 px-3 py-1 text-sm text-sky-100">
        <%= Rails.application.config.chat["chat_provider"].to_s.humanize %>: <%= Rails.application.config.chat["chat_model"] %>
      </div>
    </header>

    <section id="messages"
             class="flex-1 space-y-4 overflow-y-auto py-4"
             data-controller="scroll"
             data-scroll-delay-value="25">
      <% @messages.each do |message| %>
        <%= render "chat/message", message: message %>
      <% end %>
    </section>

    <footer class="sticky bottom-0 border-t border-white/10 bg-slate-950/90 pt-4 backdrop-blur">
      <%= turbo_frame_tag "chat_errors" do %>
        <%= render "chat/errors", error_message: nil %>
      <% end %>

      <%= turbo_frame_tag "composer" do %>
        <%= render "chat/composer", chat: @chat, message: Message.new %>
      <% end %>
    </footer>
  </main>
</div>
