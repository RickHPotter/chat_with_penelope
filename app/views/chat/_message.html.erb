<% if message.assistant? %>
  <%= render "chat/assistant_message", message: message %>
<% elsif message.system? %>
  <div id="<%= dom_id(message) %>" class="flex justify-center">
    <div class="max-w-2xl rounded-3xl border border-rose-500/20 bg-rose-500/10 px-4 py-3 text-sm text-rose-100">
      <%= markdown_like(message.content_default_language) %>
    </div>
  </div>
<% else %>
  <div id="<%= dom_id(message) %>"
       class="group flex justify-end"
       data-controller="message">
    <div class="max-w-2xl overflow-hidden rounded-3xl rounded-br-lg border border-sky-200/40 bg-gradient-to-br from-sky-300 to-cyan-200 shadow-lg shadow-sky-950/20">
      <div data-message-target="content"
           class="px-4 py-3 text-sm leading-7 text-slate-950">
        <%= markdown_like(message.content_default_language) %>
      </div>

      <div class="flex flex-wrap items-center justify-end gap-x-4 gap-y-2 border-t border-slate-950/10 bg-white/25 px-4 py-2">
        <% if message.prompt_metadata["slash_command"].present? %>
          <button type="button"
                  class="font-mono text-xs font-semibold text-slate-950 underline decoration-sky-700/40 underline-offset-4 transition hover:text-sky-950 hover:decoration-sky-950"
                  data-action="message#useIntent"
                  data-intent="<%= message.prompt_metadata["slash_command"] %>">
            /<%= message.prompt_metadata["slash_command"] %>
          </button>
        <% end %>

        <button type="button"
                class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-700 underline decoration-slate-700/30 underline-offset-4 transition hover:text-slate-950 hover:decoration-slate-950"
                data-action="message#copy">
          Copy
        </button>
        <button type="button"
                class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-700 underline decoration-slate-700/30 underline-offset-4 transition hover:text-slate-950 hover:decoration-slate-950"
                data-action="message#copyDebug">
          Debug
        </button>
      </div>

      <script type="application/json" data-message-target="debugPayload"><%= json_escape(message_debug_payload(message)) %></script>
    </div>
  </div>
<% end %>
