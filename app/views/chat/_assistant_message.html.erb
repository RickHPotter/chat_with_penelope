<div id="<%= dom_id(message) %>"
     class="rounded-3xl border border-white/10 bg-white/5 p-4 shadow-lg shadow-black/10"
     data-controller="message"
     data-message-default-tab-class="bg-white text-slate-950"
     data-message-default-tab-inactive-class="text-slate-300 hover:text-white"
     data-message-target-tab-class="bg-white text-slate-950"
     data-message-target-tab-inactive-class="text-slate-300 hover:text-white"
     data-message-language-value="target">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div class="inline-flex rounded-full border border-white/10 bg-slate-950/70 p-1 text-xs font-medium">
      <button type="button"
              class="rounded-full px-3 py-1 transition"
              data-message-target="targetTab"
              data-action="message#showTarget">
        Français
      </button>
      <button type="button"
              class="rounded-full px-3 py-1 transition"
              data-message-target="defaultTab"
              data-action="message#showDefault">
        English
      </button>
    </div>

    <div class="flex items-center gap-2">
      <button type="button"
              class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium text-white transition hover:bg-white/10"
              data-action="message#copy">
        Copy
      </button>

      <%= button_to "Reprompt",
        chat_message_reprompt_path(message),
        method: :post,
        form: { class: "inline", data: { turbo_stream: true } },
        class: "rounded-full border border-sky-400/30 bg-sky-400/10 px-3 py-1 text-xs font-medium text-sky-100 transition hover:bg-sky-400/20" %>
    </div>
  </div>

  <div class="mt-4 space-y-3 text-sm leading-7 text-slate-100">
    <div data-message-target="targetPanel" class="whitespace-pre-wrap">
      <%= message.content_target_language %>
    </div>

    <div data-message-target="defaultPanel" class="whitespace-pre-wrap">
      <%= message.content_default_language %>
    </div>
  </div>
</div>
