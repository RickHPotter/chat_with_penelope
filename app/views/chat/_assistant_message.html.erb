<div id="<%= dom_id(message) %>"
     class="group overflow-hidden rounded-[1.75rem] border border-white/10 bg-slate-900/80 shadow-xl shadow-black/20 ring-1 ring-white/5 backdrop-blur"
     data-controller="message"
     data-message-default-tab-class="bg-white text-slate-950 shadow-sm"
     data-message-default-tab-inactive-class="text-slate-300 hover:text-white"
     data-message-target-tab-class="bg-white text-slate-950 shadow-sm"
     data-message-target-tab-inactive-class="text-slate-300 hover:text-white"
     data-message-language-value="target">
  <div class="flex flex-wrap items-center justify-between gap-3 border-b border-white/10 bg-white/[0.03] px-4 py-3">
    <div class="inline-flex rounded-full border border-white/10 bg-slate-950/70 p-1 text-xs font-medium">
      <button type="button"
              class="rounded-full px-3 py-1 transition"
              data-message-target="targetTab"
              data-action="message#showTarget">
        Français
      </button>
      <button type="button"
              class="rounded-full px-3 py-1 transition"
              data-message-target="defaultTab"
              data-action="message#showDefault">
        English
      </button>
    </div>

    <% if message.generating? || message.cancelling? || message.cancelled? %>
      <div class="rounded-full border border-sky-300/20 bg-sky-300/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.22em] text-sky-100">
        <%= message.generation_status %>
      </div>
    <% end %>
  </div>

  <div class="px-4 py-4">
    <% if message.content_thinking.present? %>
      <details class="mb-4 rounded-2xl border border-white/10 bg-slate-950/60 px-4 py-3 text-xs leading-6 text-slate-300">
        <summary class="cursor-pointer font-semibold text-slate-100">Thinking</summary>
        <div id="<%= dom_id(message, :thinking_stream) %>"
             class="mt-3 max-h-48 overflow-y-auto whitespace-pre-wrap opacity-75">
          <%= message.content_thinking %>
        </div>
      </details>
    <% elsif message.generating? || message.cancelling? %>
      <details class="mb-4 rounded-2xl border border-white/10 bg-slate-950/60 px-4 py-3 text-xs leading-6 text-slate-300" open>
        <summary class="cursor-pointer font-semibold text-slate-100">Thinking</summary>
        <div id="<%= dom_id(message, :thinking_stream) %>"
             class="mt-3 max-h-48 overflow-y-auto whitespace-pre-wrap opacity-75"></div>
      </details>
    <% end %>

    <div class="text-sm text-slate-100">
      <div id="<%= dom_id(message, :target_stream) %>"
           data-message-target="targetPanel"
           class="markdown-like">
        <%= markdown_like(message.content_target_language) %>
      </div>

      <div id="<%= dom_id(message, :default_stream) %>"
           data-message-target="defaultPanel"
           class="markdown-like">
        <%= markdown_like(message.content_default_language) %>
      </div>
    </div>
  </div>

  <div class="flex flex-wrap items-center justify-end gap-2 border-t border-white/10 bg-slate-950/40 px-3 py-2">
    <button type="button"
            class="rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-300 transition hover:bg-white/10 hover:text-white"
            data-action="message#copy">
      Copy
    </button>

    <%= button_to "Reprompt",
      chat_message_reprompt_path(message),
      method: :post,
      form: { class: "inline", data: { turbo_stream: true } },
      class: "rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-sky-200 transition hover:bg-sky-400/10 hover:text-sky-100" %>

    <button type="button"
            class="rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-200 transition hover:bg-amber-300/10 hover:text-amber-100"
            data-action="message#copyDebug">
      Debug
    </button>

    <% if message.generating? || message.cancelling? %>
      <%= button_to "Cancel",
        chat_message_cancel_path(message),
        method: :post,
        form: { class: "inline", data: { turbo_stream: true } },
        class: "rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-rose-200 transition hover:bg-rose-400/10 hover:text-rose-100" %>
    <% end %>
  </div>

  <script type="application/json" data-message-target="debugPayload"><%= json_escape(message_debug_payload(message)) %></script>
</div>
