<div class="mx-auto flex min-h-screen max-w-5xl items-center px-6 py-16">
  <div class="max-w-2xl space-y-8">
    <div class="inline-flex rounded-full border border-sky-400/30 bg-sky-400/10 px-4 py-2 text-sm font-medium text-sky-200">
      Using model: <%= Rails.application.config.chat["chat_model"] %>
    </div>

    <div class="space-y-4">
      <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-6xl">
        Chat with Penelope
      </h1>
      <p class="text-lg leading-8 text-slate-300 sm:text-xl">
        A local-first chatbot built on Ollama, Turbo, and streaming updates over Solid Cable.
      </p>
    </div>
  </div>
</div>
